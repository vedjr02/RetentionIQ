# Frontend environment (copy to frontend/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Vercel production (same-origin — API served at /api/* on same domain):
# NEXT_PUBLIC_API_URL=

# Separate API host (Railway) if not using Vercel multi-service:
# NEXT_PUBLIC_API_URL=https://your-api.railway.app
